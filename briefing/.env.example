ANTHROPIC_API_KEY=sk-ant-...
# Haiku is ~3x cheaper and plenty capable for this task.
# Override to claude-sonnet-4-6 or claude-opus-4-7 for richer summaries.
ANTHROPIC_MODEL=claude-haiku-4-5

# How many characters of the RSS excerpt to send to Claude per article.
# 800 is plenty for scoring + a short summary. Raise for longer content.
EXCERPT_CHARS=800

# Tuning
MAX_ARTICLES_PER_FEED=15
CURATION_CONCURRENCY=4

# Your interests, in priority order (comma-separated). Leave blank to use defaults.
# Example: Economic policy, AI regulation, Federal Reserve, Prediction markets, Tech & startups
BRIEFING_INTERESTS=

# Summary length: short (2-3 sentences), medium (4-5), long (6-8)
SUMMARY_LENGTH=short

# Required on Vercel — Upstash Redis from the Vercel Marketplace auto-injects these
# (or use UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Required on Vercel to protect the cron endpoint
CRON_SECRET=generate-a-random-string
